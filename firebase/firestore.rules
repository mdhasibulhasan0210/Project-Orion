rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Devices ───────────────────────────────────────────────────────────────
    // Users read/write only their own devices
    match /devices/{deviceId} {
      allow read: if request.auth != null && (
        resource == null || resource.data.userId == request.auth.uid
      );
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid
      );
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Device Status ──────────────────────────────────────────────────────────
    // Agent writes (it is authenticated), dashboard user reads
    match /deviceStatus/{deviceId} {
      allow write: if request.auth != null;
      allow read: if request.auth != null;
    }

    // ── Commands ──────────────────────────────────────────────────────────────
    // Dashboard creates signed commands; agent reads + updates status
    match /commands/{commandId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
      allow delete: if false; // immutable audit trail
    }

    // ── Command Results ───────────────────────────────────────────────────────
    // Agent writes results; user reads
    match /commandResults/{commandId} {
      allow write: if request.auth != null;
      allow read: if request.auth != null;
    }

    // ── Settings ──────────────────────────────────────────────────────────────
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Activity Logs ─────────────────────────────────────────────────────────
    match /activityLogs/{userId}/logs/{logId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
  }
}
